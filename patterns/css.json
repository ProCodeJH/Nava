{
    "name": "css",
    "description": "Generic CSS animation patterns → GSAP/Motion mapping",
    "version": "1.0.0",
    "transitions": {
        "fade": {
            "cssProperty": "opacity",
            "from": "0",
            "to": "1",
            "gsap": "gsap.from(el, { opacity: 0, duration: 0.8 })",
            "motion": "{ initial: { opacity: 0 }, animate: { opacity: 1 } }"
        },
        "slideUp": {
            "cssProperty": "transform",
            "from": "translateY(50px)",
            "to": "translateY(0)",
            "gsap": "gsap.from(el, { y: 50, opacity: 0, duration: 0.8 })",
            "motion": "{ initial: { y: 50, opacity: 0 }, animate: { y: 0, opacity: 1 } }"
        },
        "slideLeft": {
            "cssProperty": "transform",
            "from": "translateX(-100px)",
            "to": "translateX(0)",
            "gsap": "gsap.from(el, { x: -100, opacity: 0, duration: 0.8 })",
            "motion": "{ initial: { x: -100, opacity: 0 }, animate: { x: 0, opacity: 1 } }"
        },
        "slideRight": {
            "cssProperty": "transform",
            "from": "translateX(100px)",
            "to": "translateX(0)",
            "gsap": "gsap.from(el, { x: 100, opacity: 0, duration: 0.8 })",
            "motion": "{ initial: { x: 100, opacity: 0 }, animate: { x: 0, opacity: 1 } }"
        },
        "scaleUp": {
            "cssProperty": "transform",
            "from": "scale(0.8)",
            "to": "scale(1)",
            "gsap": "gsap.from(el, { scale: 0.8, opacity: 0, duration: 0.8 })",
            "motion": "{ initial: { scale: 0.8, opacity: 0 }, animate: { scale: 1, opacity: 1 } }"
        },
        "rotate": {
            "cssProperty": "transform",
            "from": "rotate(-10deg)",
            "to": "rotate(0deg)",
            "gsap": "gsap.from(el, { rotation: -10, duration: 0.8 })",
            "motion": "{ initial: { rotate: -10 }, animate: { rotate: 0 } }"
        }
    },
    "keyframePatterns": {
        "spin": {
            "detect": "0%: rotate(0deg) → 100%: rotate(360deg)",
            "gsap": "gsap.to(el, { rotation: 360, duration: 2, repeat: -1, ease: 'none' })",
            "motion": "{ animate: { rotate: 360 }, transition: { duration: 2, repeat: Infinity, ease: 'linear' } }"
        },
        "pulse": {
            "detect": "0%: scale(1) → 50%: scale(1.05) → 100%: scale(1)",
            "gsap": "gsap.to(el, { scale: 1.05, duration: 1, yoyo: true, repeat: -1 })",
            "motion": "{ animate: { scale: [1, 1.05, 1] }, transition: { duration: 2, repeat: Infinity } }"
        },
        "bounce": {
            "detect": "translateY oscillation with ease-out",
            "gsap": "gsap.to(el, { y: -20, duration: 0.6, yoyo: true, repeat: -1, ease: 'power2.out' })",
            "motion": "{ animate: { y: [0, -20, 0] }, transition: { duration: 1.2, repeat: Infinity } }"
        },
        "float": {
            "detect": "translateY slow oscillation 10-20px",
            "gsap": "gsap.to(el, { y: '+=15', duration: 3, yoyo: true, repeat: -1, ease: 'sine.inOut' })",
            "motion": "{ animate: { y: [0, 15, 0] }, transition: { duration: 6, repeat: Infinity, ease: 'easeInOut' } }"
        },
        "shimmer": {
            "detect": "background-position or gradient animation",
            "gsap": "gsap.to(el, { backgroundPosition: '200% 0', duration: 2, repeat: -1, ease: 'none' })",
            "motion": null
        },
        "marquee": {
            "detect": "translateX from 0 to -50% or -100% with infinite repeat",
            "gsap": "gsap.to(el, { xPercent: -50, duration: 15, repeat: -1, ease: 'none' })",
            "motion": null
        }
    },
    "easings": {
        "framerSpring": "{ type: 'spring', stiffness: 300, damping: 30 }",
        "gsapPower3Out": "'power3.out'",
        "cubicBezier": "cubic-bezier(0.16, 1, 0.3, 1) → [0.16, 1, 0.3, 1]",
        "easeOutExpo": "'expo.out'"
    }
}