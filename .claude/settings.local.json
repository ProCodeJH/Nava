      "Bash(node -e \"\nconst fs = require\\('fs'\\);\nlet html = fs.readFileSync\\('C:/Users/exodia/.local/bin/Nava/Nava/naba-tools/design-final.html', 'utf8'\\);\n// 민서진 — nextPlan만 변경\nlet min = html.replace\\(\n  'AI가 만든 정보와 사람이 만든 정보를 구별하는 방법 학습 \\(가짜 뉴스 탐지 기초\\)',\n  '소프트웨어 코딩으로 마이크로프로세서 하드웨어를 제어하기'\n\\);\nfs.writeFileSync\\('C:/Users/exodia/.local/bin/Nava/Nava/naba-tools/min-final.html', min, 'utf8'\\);\n\n// 김우현 — 학생명, 태도, 이해도, 추가전달 변경\nlet kim = min\n  .replace\\('민서진', '김우현'\\)\n  .replace\\(\n    '수업 내내 호기심을 갖고 적극적으로 참여하였으며, AI에게 질문하는 활동에서 자신만의 질문을 스스로 만들어내는 모습이 인상적이었습니다.',\n    '처음에는 \\\\\\\\\\\\\"AI가 틀릴 수도 있어요?\\\\\\\\\\\\\"라며 놀라는 반응을 보였으나, 실습을 통해 직접 확인하면서 점차 비판적 시각을 갖기 시작했습니다. 실습 참여도가 매우 높았습니다.'\n  \\)\n  .replace\\(\n    'AI가 항상 정확하지 않을 수 있다는 개념을 자연스럽게 받아들이며, 논리적 질문 구조에 대한 이해도가 높은 편입니다.',\n    '페르소나 개념과 논리적 질문법은 잘 이해하였으며, 교차 검증 부분은 조금 더 연습이 필요합니다. 꾸준히 반복하면 빠르게 익힐 수 있을 것으로 보입니다.'\n  \\)\n  .replace\\(\n    '가정에서 아이가 AI를 사용할 때 \\\\\\\\\\\\\"이 답이 왜 맞아?\\\\\\\\\\\\\"라고 한 번만 같이 물어봐 주시면 수업 효과가 훨씬 커집니다.',\n    '\\\\\\\\\\\\\"AI도 틀릴 수 있다\\\\\\\\\\\\\"는 사실에 아이가 큰 흥미를 보였습니다. 집에서도 AI와 함께 정보를 찾아볼 때 정답을 직접 확인해보는 습관을 함께 만들어 주시면 좋겠습니다.'\n  \\);\nfs.writeFileSync\\('C:/Users/exodia/.local/bin/Nava/Nava/naba-tools/kim-final.html', kim, 'utf8'\\);\nconsole.log\\('done'\\);\n\")",
